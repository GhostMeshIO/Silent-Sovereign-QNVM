  "operators": [
    {
      "symbol": "𝒫̂",
      "name": "Precision Operator",
      "definition": "Modulates Bayesian precision – how strongly the brain weights incoming information.",
      "properties": []
    },
    {
      "symbol": "ℬ̂",
      "name": "Boundary Operator",
      "definition": "Modulates Markov blanket permeability – clarity of self-world demarcation.",
      "properties": []
    },
    {
      "symbol": "𝒯̂",
