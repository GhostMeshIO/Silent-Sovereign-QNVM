  "mechanisms": [
    {
      "name": "Bayesian precision weighting",
      "function": "lambda state: state.get('precision', 0.5)"
    },
    {
      "name": "Markov blanket boundaries",
      "function": "lambda state: state.get('boundary', 0.5)"
    },
    {
      "name": "Hyperbolic temporal discounting",
