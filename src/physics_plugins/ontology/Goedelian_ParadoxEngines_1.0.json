    {
      "name": "Paradox intensity",
      "function": "lambda state: abs(state.get('true', 0) - state.get('false', 0)) / (math.sqrt(state.get('true',0)**2 + state.get('false',0)**2) + 1e-9)"
    },
    {
      "name": "Scale‑dependent Gödel anomaly",
      "function": "lambda state: state.get('anomaly', 0) * (1 + math.sin(state.get('scale', 1)))"
    }
