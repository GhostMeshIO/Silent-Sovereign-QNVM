      "equations": [
        {
          "name": "Master Equation",
          "latex": "\\Psi_{\\text{mind}}(t) = \\mathcal{F}(\\pi_{\\text{precision}}, \\partial B_{\\text{boundary}}, \\gamma_{\\text{temporal}}) + \\xi_{\\text{plasticity}}"
        },
        {
          "name": "Precision Dynamics",
          "latex": "\\frac{d\\pi}{dt} = -\\kappa(\\pi - \\pi_0) + \\beta \\cdot \\delta^2 + \\gamma \\cdot [DA/NE/5HT] + \\sigma \\xi(t)"
        },
        {
          "name": "Boundary Dynamics",
          "latex": "\\frac{d(\\partial B)}{dt} = -\\alpha(\\partial B - \\partial B_0) + \\beta \\cdot \\text{stress}(t) + \\gamma \\cdot \\text{attachment}_{\\text{early}} + \\sigma \\xi(t)"
        },
        {
          "name": "Temporal Dynamics",
          "latex": "\\frac{d\\gamma}{dt} = -\\kappa(\\gamma - \\gamma_0) + \\beta_{\\text{stress}} \\cdot S(t) + \\eta_{\\text{trauma}} \\cdot T(t) + \\alpha_{\\text{reward}} \\cdot R(t)"
        },
        {
          "name": "Comorbidity Distance",
          "latex": "d(A,B) = \\sqrt{(\\mathcal{P}_A-\\mathcal{P}_B)^2 + (\\mathcal{B}_A-\\mathcal{B}_B)^2 + (\\mathcal{T}_A-\\mathcal{T}_B)^2}"
        }
      ],
      "mechanisms": [
        "Bayesian precision weighting",
        "Markov blanket boundaries",
        "Hyperbolic temporal discounting",
        "Prediction error (δ) processing"
      ],
      "implications": [
        "All mental disorders are coordinates in 𝒟³-space.",
        "Treatment = vector recalibration toward origin (0,0,0).",
        "Comorbidity follows geometric rules: P(comorbid) ∝ e^{-d(A,B)/σ}.",
        "Axis setpoints vary by culture and early experience.",
        "Mental health is dynamic stability within healthy ranges, not fixed point."
      ]
    }
